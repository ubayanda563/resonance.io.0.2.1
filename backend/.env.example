# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=resonance

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Free APIs (no key needed) ─────────────────────────────────────────────────
# MusicBrainz — https://musicbrainz.org  (completely free, no key)
# Deezer       — https://developers.deezer.com  (completely free, no key)
# lrclib       — https://lrclib.net  (completely free, no key)

# ── APIs requiring free keys ──────────────────────────────────────────────────
# Last.fm — https://www.last.fm/api/account/create  (free, get API key instantly)
LASTFM_API_KEY=

# AcoustID — https://acoustid.org/login  (free, for audio fingerprinting)
# Also requires: apt install chromaprint-tools
ACOUSTID_API_KEY=

# RapidAPI — https://rapidapi.com  (Shazam Core: 500 req/month free tier)
# Subscribe at: https://rapidapi.com/apidojo/api/shazam-core
RAPIDAPI_KEY=
